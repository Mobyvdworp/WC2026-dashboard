function poiCompute(){
  // clone priors into mutable ratings
  const R={};Object.keys(POI.priors).forEach(n=>R[n]={att:POI.priors[n].att,def:POI.priors[n].def});
  const base=POI.baseline, homeF=POI.home;
  const HOSTSET=new Set(HOSTS);
  // ordered list of played matches by date for sequential updating
  const played=[];
  DATA.matches.forEach(m=>{
    const res=effective(m);
    if(res){played.push({m,res});}
  });
  played.sort((a,b)=>a.m.sortdate.localeCompare(b.m.sortdate));
  // sequential gentle update
  let count=0;const total=Math.max(1,played.length);
  played.forEach(({m,res})=>{
