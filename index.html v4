function poolStandings(p){
  const pt=teams.filter(t=>t.pool===p);
  const pts={},w={},d={},l={};
  pt.forEach(t=>{pts[t.name]=0;w[t.name]=0;d[t.name]=0;l[t.name]=0});
  DATA.matches.filter(m=>m.pool===p).forEach(m=>{
    if(m.predicted==='Too close to call'){pts[m.team1]+=1;pts[m.team2]+=1;d[m.team1]++;d[m.team2]++;}
    else{const loser=m.predicted===m.team1?m.team2:m.team1;pts[m.predicted]+=3;w[m.predicted]++;l[loser]++;}
  });
  return pt.map(t=>({name:t.name,pts:pts[t.name],w:w[t.name],d:d[t.name],l:l[t.name],comp:t.composite}))
    .sort((a,b)=>b.pts-a.pts||b.comp-a.comp);
}
