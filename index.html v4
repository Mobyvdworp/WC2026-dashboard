  [0,.005,.02,.05,.10,.167].forEach(v=>{
    g+=`<text x="${x(v)}" y="${P.t+ih+20}" fill="#8b93c4" font-size="11" text-anchor="middle">${(v*100).toFixed(1)}%</text>`;
    g+=`<line x1="${x(v)}" y1="${P.t}" x2="${x(v)}" y2="${P.t+ih}" stroke="#1d2450" stroke-dasharray="3 4"/>`;
  });
  [0,.25,.5,.75,1].forEach(v=>{
    g+=`<text x="${P.l-10}" y="${y(v)+4}" fill="#8b93c4" font-size="11" text-anchor="end">${v.toFixed(2)}</text>`;
    g+=`<line x1="${P.l}" y1="${y(v)}" x2="${P.l+iw}" y2="${y(v)}" stroke="#1d2450" stroke-dasharray="3 4"/>`;
  });
  g+=`<text x="${P.l+iw/2}" y="${H-8}" fill="#8b93c4" font-size="12" text-anchor="middle">MARKET IMPLIED PROBABILITY (sqrt scale)</text>`;
  g+=`<text x="16" y="${P.t+ih/2}" fill="#8b93c4" font-size="12" text-anchor="middle" transform="rotate(-90 16 ${P.t+ih/2})">COMPOSITE SCORE</text>`;
  // trendline: least squares in plotted pixel space
  const pts=teams.filter(t=>t.implied!=null).map(t=>({px:x(t.implied),py:y(t.composite)}));
  const n=pts.length;
  const mx=pts.reduce((s,p)=>s+p.px,0)/n, my=pts.reduce((s,p)=>s+p.py,0)/n;
  let num=0,den=0;
  pts.forEach(p=>{num+=(p.px-mx)*(p.py-my);den+=(p.px-mx)**2;});
  const slope=num/den, icept=my-slope*mx;
  const yAt=px=>Math.max(P.t,Math.min(P.t+ih,icept+slope*px));
  g+=`<line x1="${P.l}" y1="${yAt(P.l)}" x2="${P.l+iw}" y2="${yAt(P.l+iw)}" stroke="#f5c84c" stroke-width="1.5" stroke-dasharray="7 5" opacity=".7"/>`;
  g+=`<text x="${P.l+iw-6}" y="${yAt(P.l+iw)-8}" fill="#f5c84c" font-size="11" text-anchor="end">trend</text>`;
  teams.forEach((t,i)=>{
    if(t.implied==null)return;
