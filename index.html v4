    const disagree=p.favProb<0.5;
    g+=`<circle class="mm-pt" data-i="${i}" cx="${x(p.favImplied)}" cy="${y(p.favProb)}" r="5" fill="${disagree?'#f5564c':'#4cf5a8'}" fill-opacity=".82"/>`;
  });
  svg.innerHTML=g;
  const tip=document.getElementById('mm-tip');const box=svg.parentElement;
  svg.querySelectorAll('.mm-pt').forEach(c=>{
    c.addEventListener('mousemove',e=>{
      const p=pts[+c.dataset.i];
      tip.innerHTML=`<div class="tt-name">${p.m.team1} vs ${p.m.team2}</div>
        <div class="tt-row">Market fav: <b>${p.fav}</b> (${(p.favImplied*100).toFixed(1)}%)</div>
        <div class="tt-row">Poisson gives ${p.fav}: <b>${Math.round(p.favProb*100)}%</b></div>`;
      const r=box.getBoundingClientRect();
      tip.style.left=Math.min(e.clientX-r.left+14,r.width-180)+'px';
      tip.style.top=(e.clientY-r.top-10)+'px';tip.style.display='block';
    });
    c.addEventListener('mouseleave',()=>tip.style.display='none');
  });
}
document.getElementById('poi-sortbar').addEventListener('click',e=>{
  const b=e.target.closest('button');if(!b)return;
  if(b.dataset.psort){document.querySelectorAll('#poi-sortbar [data-psort]').forEach(x=>x.classList.remove('active'));b.classList.add('active');poiSort=b.dataset.psort;}
  if(b.dataset.pfilter){document.querySelectorAll('#poi-sortbar [data-pfilter]').forEach(x=>x.classList.remove('active'));b.classList.add('active');poiFilter=b.dataset.pfilter;}
  renderPoisson();
});
document.getElementById('poi-refresh').addEventListener('click',async()=>{await fetchFeed();renderPoisson();});
let poiInit=false;

/* ---------- NAV ---------- */
document.querySelectorAll('nav button').forEach(b=>{
  b.onclick=()=>{
    document.querySelectorAll('nav button').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    document.getElementById(b.dataset.page).classList.add('active');
    if(b.dataset.page==='live'&&!liveFetched){liveFetched=true;fetchFeed();}
    if(b.dataset.page==='poisson'){if(!liveFetched){liveFetched=true;fetchFeed().then(renderPoisson);}else{renderPoisson();}}
    if(b.dataset.page==='market'){if(!liveFetched){liveFetched=true;fetchFeed().then(()=>{renderPoisson();renderMarketCompare();});}else{renderMarketCompare();}}
    window.scrollTo({top:0});
  };
});
</script>
