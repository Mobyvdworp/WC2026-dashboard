function outcomeOf(m,res){
  if(!res)return null;
  const tctc=m.predicted==='Too close to call';
  if(res.s1===res.s2)return tctc?'tctc-draw':'draw';
  const winner=res.s1>res.s2?m.team1:m.team2;
  if(tctc)return 'tctc-decided';
  return winner===m.predicted?'ok':'bad';
