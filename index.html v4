async function fetchFeed(){
  const btn=document.getElementById('refresh-btn'),st=document.getElementById('live-status');
  btn.disabled=true;st.textContent='Fetching…';
  try{
    let j=null,lastErr=null;
    for(const u of FEED_URLS){
      try{const r=await fetch(u,{cache:'no-store'});if(!r.ok)throw new Error('HTTP '+r.status);j=await r.json();break;}
      catch(err){lastErr=err;}
    }
    if(!j)throw lastErr||new Error('all sources failed');
    let found=0;
    (j.matches||[]).forEach(fm=>{
