function renderTileMap(el,lat,lon,z){
  el.innerHTML='';
  const w=el.clientWidth||560,h=el.clientHeight||280,n=Math.pow(2,z);
  const rad=lat*Math.PI/180;
  const cx=((lon+180)/360)*n*256;
  const cy=((1-Math.log(Math.tan(rad)+1/Math.cos(rad))/Math.PI)/2)*n*256;
  const x0=cx-w/2,y0=cy-h/2;
  const tx0=Math.floor(x0/256),ty0=Math.floor(y0/256);
  const tx1=Math.floor((x0+w)/256),ty1=Math.floor((y0+h)/256);
  for(let tx=tx0;tx<=tx1;tx++)for(let ty=ty0;ty<=ty1;ty++){
    if(ty<0||ty>=n)continue;
    const img=document.createElement('img');
    img.className='map-tile';img.alt='';
    img.referrerPolicy='no-referrer-when-downgrade';
    img.src=`https://tile.openstreetmap.org/${z}/${((tx%n)+n)%n}/${ty}.png`;
    img.onerror=function(){this.style.display='none';};
    img.style.left=(tx*256-x0)+'px';img.style.top=(ty*256-y0)+'px';
    el.appendChild(img);
  }
  const pin=document.createElement('div');pin.className='map-pin';el.appendChild(pin);
}

